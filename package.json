    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "mcp",
    "philippines",
    "bsp",
    "banking",
    "financial-inclusion",
    "psgc",
    "cloudflare-workers"
  ],
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "cf-typegen": "wrangler types",
